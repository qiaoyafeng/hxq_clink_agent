# 天润融通 PCM 语音流实时推送 FastAPI Server 配置

# ── Server 监听配置 ──
HXQ_HOST=0.0.0.0
HXQ_PORT=8000
HXQ_WS_PATH=/realtime_voice
HXQ_PRODUCTION=true

# ── 并发控制 ──
HXQ_MAX_CONCURRENT_SESSIONS=2  # 同时进行的最大会话数，0 表示不限制

# ── 鉴权配置（用于验证天润融通客户端签名） ──
HXQ_AUTH_ENABLED=true
HXQ_APP_ID=8008939
HXQ_ACCESS_KEY_ID=dc9ddf3c8f7cbcb45a3ec6bad93c72c8
HXQ_ACCESS_KEY_SECRET=X9b3O90k6Dc82KO05TN3

# ── PCM 参数（默认 8kHz / 16bit / 960B / 60ms，符合天润融通协议规范） ──
HXQ_PCM_SAMPLE_RATE=8000
HXQ_PCM_SAMPLE_WIDTH=16
HXQ_PCM_FRAME_SIZE=960
HXQ_PCM_FRAME_INTERVAL=0.06

# ── VAD 参数 ──
HXQ_VAD_SILENCE_SEC=0.8
HXQ_VAD_ENERGY_THRESHOLD=500

# ── 日志 ──
HXQ_LOG_LEVEL=INFO
HXQ_ACCESS_LOG=false
# HXQ_LOG_FILE=logs/app_{time:YYYY-MM-DD}.log   # 支持 {time} 占位符，按日期生成文件名
# HXQ_LOG_ROTATION=00:00                            # 每天午夜轮转
# HXQ_LOG_RETENTION=7 days                           # 日志保留天数

# ── 运行模式 ──
# HXQ_USE_STUB=false  # 设为 true 使用 Stub 适配器（开发调试用，会覆盖所有 provider 为 stub）

# ── Provider 选择（通过环境变量切换 ASR/LLM/TTS 实现） ──
# HXQ_ASR_PROVIDER=dashscope    # 可选: stub | dashscope | funasr
# HXQ_LLM_PROVIDER=openai       # 可选: stub | openai
# HXQ_TTS_PROVIDER=dashscope    # 可选: stub | dashscope

# ── DashScope API Key（ASR / LLM / TTS 共用） ──
HXQ_DASHSCOPE_API_KEY=your-dashscope-api-key-here

# ── ASR 配置（阿里云 Paraformer） ──
# HXQ_ASR_MODEL=paraformer-realtime-8k-v2
# HXQ_ASR_STREAMING_ENABLED=true
# HXQ_ASR_MAX_SENTENCE_SILENCE=800

# ── 打断（Barge-in）配置 ──
HXQ_BARGE_IN_ENABLED=true  # 用户说话时自动取消当前 LLM/TTS 生成

# ── 转人工（Transfer to Agent）配置 ──
HXQ_TRANSFER_ENABLED=true                                     # 是否启用转人工（关键词识别触发）
HXQ_TRANSFER_KEYWORDS=转人工,人工客服,人工服务,转接人工,找人工   # 触发关键词，逗号分隔
HXQ_TRANSFER_QNO=9999                                          # 转人工目标队列号

# ── LLM 配置（OpenAI 兼容接口） ──
# HXQ_LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# HXQ_LLM_MODEL=qwen-turbo
# HXQ_LLM_SYSTEM_PROMPT=你是一个智能语音助手，请用简洁的语言回答用户的问题。

# ── TTS 配置（阿里云 CosyVoice REST API） ──
# HXQ_TTS_BASE_URL=https://dashscope.aliyuncs.com/api/v1
# HXQ_TTS_MODEL=cosyvoice-v2-0.5b
# HXQ_TTS_VOICE=longxiaochun_v2
# HXQ_TTS_SAMPLE_RATE=22050

# ── Voice-to-Voice Provider（留空=使用ASR-LLM-TTS管线；设为baidu=使用百度RTC） ──
# HXQ_VOICE_PROVIDER=baidu

# ── 百度RTC大模型互动服务配置 ──
HXQ_BAIDU_RTC_APP_ID=your-baidu-rtc-app-id
HXQ_BAIDU_RTC_AK=your-baidu-ak
HXQ_BAIDU_RTC_SK=your-baidu-sk
HXQ_BAIDU_RTC_LICENSE_KEY=your-license-key
# HXQ_BAIDU_RTC_DEVICE_ID=hxq_clink_agent
# HXQ_BAIDU_RTC_USER_ID=default_user
# HXQ_BAIDU_RTC_API_ENDPOINT=rtc-aiagent.baidubce.com
# HXQ_BAIDU_RTC_WS_ENDPOINT=wss://rtc-aiotgw.exp.bcelive.com/v1/realtime
# HXQ_BAIDU_RTC_AUDIO_CODEC=raw16k          # raw16k | pcmu | opus_cbr_16000

# 百度RTC模式选择（端到端 vs 传统托管）
# HXQ_BAIDU_RTC_E2E_ENABLED=false            # true=端到端语音模型(audio_to_audio), false=传统托管模式
# HXQ_BAIDU_RTC_E2E_PROMPT=你是一个智能语音助手   # 端到端模型角色提示词
# HXQ_BAIDU_RTC_E2E_VCN=8003                 # 端到端模型音色(8003/8014/8008/8021)

# 百度RTC传统托管模式配置（E2E_ENABLED=false 时生效）
# HXQ_BAIDU_RTC_SCENE_ROLE_NAME=             # 控制台预设角色名（与 SCENE_ROLE_PROMPT 二选一）
# HXQ_BAIDU_RTC_SCENE_ROLE_PROMPT=           # 临时角色 prompt
# HXQ_BAIDU_RTC_TTS_VCN=                     # TTS 发音人
# HXQ_BAIDU_RTC_TTS_SAYHI=你好，请问有什么可以帮您  # 招呼语
# HXQ_BAIDU_RTC_LANG=zh                      # 语言
# HXQ_BAIDU_RTC_DISABLE_AUTO_INTERRUPT=false # 是否关闭云端自动打断
# HXQ_BAIDU_RTC_ASR_VAD=200                  # ASR 断句等待时长(ms)
